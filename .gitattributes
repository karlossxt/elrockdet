# Normalizar a LF en Git, checkout según SO
* text=auto

# Archivos específicos
*.html text eol=crlf
*.css text eol=crlf
*.js text eol=crlf
*.xml text eol=crlf
*.txt text eol=crlf
*.yml text eol=lf
*.yaml text eol=lf

# Archivos binarios
*.jpg binary
*.jpeg binary
*.png binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
